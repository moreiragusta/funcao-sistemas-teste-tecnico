## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options
.vs/

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Database files (exceto App_Data do projeto)
*.mdf
*.ldf
*.ndf
!**/App_Data/*.mdf
!**/App_Data/*.ldf
!**/App_Data/*.ndf

# Others
*.cache
*.log
*.tmp